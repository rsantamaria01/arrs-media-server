# Ignore actual config files generated by services
services/**/*
!services/**/*.template.yml
!services/**/*.template.db
!services/**/*.template.xml
!services/**/*.template.json
!services/**/*.template.log

# Keep folder structure by preserving .gitkeep files
!services/**/.gitkeep

# Ignore environment variable files
.env
.env.*
!.env.template

# Ignore Docker override files
docker-compose.override.yml

# Ignore OS-specific files
.DS_Store
Thumbs.db

# Ignore log files
*.log
