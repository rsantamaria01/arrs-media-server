# =============================================================================
# .env.template - Environment variables for arrs-media-server
# Copy this file to .env and fill in your values
# cp .env.template .env
# =============================================================================

# -----------------------------------------------------------------------------
# User and Group ID
# Run `id` to find your PUID and PGID
# If running as root use 0
# -----------------------------------------------------------------------------
PUID=0
PGID=0

# -----------------------------------------------------------------------------
# Timezone
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# Examples:
#   America/New_York
#   America/Los_Angeles
#   America/Guayaquil
#   Europe/London
#   Asia/Tokyo
# -----------------------------------------------------------------------------
TZ=America/New_York

# -----------------------------------------------------------------------------
# Domain
# The domain used to access your services
# Example: yourdomain.com
# Services will be accessible at:
#   prowlarr.yourdomain.com
#   sonarr.yourdomain.com
#   radarr.yourdomain.com
#   lidarr.yourdomain.com
#   bazarr.yourdomain.com
#   jellyfin.yourdomain.com
#   jellyseerr.yourdomain.com
#   homarr.yourdomain.com
# -----------------------------------------------------------------------------
DOMAIN=yourdomain.com

# -----------------------------------------------------------------------------
# Homarr
# Generate with: openssl rand -hex 16
# -----------------------------------------------------------------------------
HOMARR_SECRET=your_secret_key_here

# -----------------------------------------------------------------------------
# Nginx Proxy Manager
# Default credentials on first start: admin@example.com / changeme
# Change these immediately after first login then update here
# -----------------------------------------------------------------------------
NPM_EMAIL=admin@example.com
NPM_PASSWORD=changeme