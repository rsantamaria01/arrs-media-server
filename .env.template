# =============================================================================
# .env.template - Environment variables for arrs-media-server
# Copy this file to .env and fill in your values
# cp .env.template .env
# =============================================================================

# -----------------------------------------------------------------------------
# User and Group ID
# If running as root use 0
# -----------------------------------------------------------------------------
PUID=0
PGID=0

# -----------------------------------------------------------------------------
# Timezone
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# Examples:
#   America/New_York
#   America/Los_Angeles
#   America/Guayaquil
#   Europe/London
#   Asia/Tokyo
# -----------------------------------------------------------------------------
TZ=America/New_York

# -----------------------------------------------------------------------------
# Homarr
# Generate with: openssl rand -hex 16
# -----------------------------------------------------------------------------
HOMARR_SECRET=your_secret_key_here